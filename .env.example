# Environment configuration
# Copy this file to .env and fill in your values

# Ethereum RPC URLs (required for blockchain service)
# Get free API keys from https://www.alchemy.com/ or https://infura.io/
ETHEREUM_MAINNET_RPC=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY
ETHEREUM_SEPOLIA_RPC=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
POLYGON_MAINNET_RPC=https://polygon-mainnet.g.alchemy.com/v2/YOUR_API_KEY
POLYGON_MUMBAI_RPC=https://polygon-mumbai.g.alchemy.com/v2/YOUR_API_KEY

# Database Configuration (used by Docker Compose)
POSTGRES_USER=wallet_user
POSTGRES_PASSWORD=wallet_password
POSTGRES_DB=wallet_db

# Encryption key for wallet private keys (32 bytes hex encoded)
# Generate with: openssl rand -hex 32
ENCRYPTION_SECRET_KEY=your-256-bit-secret-key-hex-encoded

# JWT Secret for authentication (if implementing auth)
JWT_SECRET=your-jwt-secret-key
